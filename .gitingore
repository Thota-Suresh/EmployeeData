# Ignore Maven build directory
/target/

# Ignore Gradle build directory
/build/

# Ignore IntelliJ IDEA project files
.idea/
*.iml

# Ignore Eclipse project files
.project
.classpath
.settings/

# Ignore NetBeans project files
nbproject/

# Ignore Visual Studio Code project files
.vscode/

# Ignore compiled Java class files
*.class

# Ignore log files
*.log

# Ignore application configuration files (you might want to commit a specific application.properties or application.yml)
application.properties
application.yml

# Ignore files for environment variables (if you use .env or similar)
.env

# Ignore dependency management files for Gradle
.gradle/

# Ignore the Spring Boot Maven Wrapper files
.mvn/

# Ignore files generated by OS (e.g., macOS, Windows)
.DS_Store
Thumbs.db

# Ignore JAR, WAR, and other generated artifacts
*.jar
*.war
*.ear

# Ignore test output
test-output/

# Ignore generated reports
*.csv
*.xml

# Ignore Maven or Gradle wrapper files (optional, if you don't want to include them)
*.bak
